{
  "expo": {
    "name": "FinPlay",
    "slug": "finpl",
    "version": "1.1.6",
    "scheme": "finpl",
    "description": "FinPlay — Learn finance through play. Gamified financial literacy for Gen-Z.",
    "platforms": [
      "ios",
      "android",
      "web"
