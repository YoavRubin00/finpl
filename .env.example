# Google OAuth Client IDs — https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Google AI (Gemini) API key — https://aistudio.google.com/apikey
EXPO_PUBLIC_GOOGLE_AI_API_KEY=AIza...

# Neon PostgreSQL — https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# API base URL (Vercel deployment)
EXPO_PUBLIC_API_URL=https://your-vercel-domain.vercel.app/api

# Alpha Vantage market data — https://www.alphavantage.co/support/#api-key
EXPO_PUBLIC_ALPHA_VANTAGE_API_KEY=your-api-key

# RevenueCat — https://app.revenuecat.com
EXPO_PUBLIC_RC_GOOGLE_KEY=goog_your_google_key_here
EXPO_PUBLIC_RC_APPLE_KEY=appl_your_apple_key_here
EXPO_PUBLIC_RC_WEBHOOK_SECRET=your-webhook-secret-here

# Sentry error tracking — https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
