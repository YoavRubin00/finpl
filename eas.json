{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://finpl.vercel.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "resourceClass": "medium",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://finpl.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "resourceClass": "large",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://finpl.vercel.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761650222"
      }
    }
  }
}
